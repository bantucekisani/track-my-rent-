OPENAI_API_KEY=

# Email notifications
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM="Track My Rent" <no-reply@trackmyrent.co.za>
EMAIL_USER=
