router.post("/upgrade",auth,async(req,res)=>{

const {plan} = req.body;

let maxUnits = 2;

if(plan==="Starter") maxUnits = 10;
if(plan==="Growth") maxUnits = 50;
if(plan==="Pro") maxUnits = -1;

await Subscription.updateOne(
{user:req.user.id},
{
plan,
maxUnits,
status:"active",
startedAt:new Date(),
expiresAt:null
}
);

res.json({success:true});

});