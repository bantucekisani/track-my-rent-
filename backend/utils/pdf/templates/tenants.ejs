<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    body { font-family: Arial, sans-serif; font-size: 12px; }
    h1 { text-align: center; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { border: 1px solid #ccc; padding: 6px; }
    th { background: #f4f4f4; }
  </style>
</head>
<body>

<h1><%= title %></h1>
<p>Generated: <%= generatedAt.toLocaleString() %></p>

<table>
  <thead>
    <tr>
      <th>#</th>
      <th>Full Name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Property</th>
      <th>Unit</th>
    </tr>
  </thead>
  <tbody>
    <% tenants.forEach((t, i) => { %>
      <tr>
        <td><%= i + 1 %></td>
        <td><%= t.fullName %></td>
        <td><%= t.email || "-" %></td>
        <td><%= t.phone || "-" %></td>
        <td><%= t.propertyId?.name || "-" %></td>
        <td><%= t.unitId?.unitLabel || "-" %></td>
      </tr>
    <% }) %>
  </tbody>
</table>

</body>
</html>
